{
  "name": "chat-adapter-backlog",
  "version": "0.1.2",
  "description": "Backlog adapter for Chat SDK",
  "keywords": [
    "backlog",
    "chat-adapter",
    "chat-sdk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/plainbrew/chat-adapter-backlog",
    "directory": "packages/chat-adapter-backlog"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@chat-adapter/shared": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "chat": "^4.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "chat": "^4.0.0"
  }
}
